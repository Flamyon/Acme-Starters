# validation-es.i18n
# Mensajes de validación globales resueltos por el MessageSource de Bean Validation.
# BaseName pattern: /WEB-INF/views/**/validation*.i18n

# ValidTicker
acme.validation.ticker.message = El formato debe comenzar con dos letras mayúsculas, seguidas de dos números, un guión y entre 5 y 10 caracteres alfanuméricos (ejemplo: AA00-ABCDE123).

# ValidStrategy (class-level)
acme.validation.strategy.message = La estrategia no es válida.
acme.validation.strategy.no-tactics.message = No se puede publicar una estrategia sin tácticas.
acme.validation.strategy.ticker-duplicated.message = Este ticker ya está en uso por otra estrategia.
acme.validation.strategy.start-null.message = La fecha de inicio es obligatoria.
acme.validation.strategy.end-null.message = La fecha de fin es obligatoria.
acme.validation.strategy.start-not-future.message = La fecha de inicio debe estar en el futuro en el momento de publicación.
acme.validation.strategy.end-not-future.message = La fecha de fin debe estar en el futuro en el momento de publicación.
acme.validation.strategy.invalid-interval.message = La fecha de inicio debe ser anterior a la fecha de fin.

# ValidText / ValidHeader (compartidas entre entidades)
acme.validation.header.message = Debe tener entre 1 y 75 caracteres
acme.validation.text.message = Debe tener entre 1 y 255 caracteres
acme.validation.object.message = Valor no válido.


# ValidSponsorship
acme.validation.ticker.message = Debe seguir el formato XX00-XXXXX (ej. ES22-Codigo1)

acme.validation.sponsorship.duplicated-ticker.message = Este ticker ya está en uso
acme.validation.sponsorship.invalid-date-order.message = La fecha de fin debe ser posterior a la de inicio
acme.validation.sponsorship.date-not-future.message = La fecha de inicio debe ser futura
acme.validation.sponsorship.missing-donations.message = Un patrocinio debe tener al menos una donación para poder publicarse
acme.validation.sponsorship.dates.error = La fecha de fin debe ser posterior a la de inicio
acme.validation.sponsorship.startMoment.future = La fecha de inicio debe ser futura
acme.validation.sponsorship.endMoment.future = La fecha de fin debe ser futura
acme.validation.sponsorship.donations.error = Debe tener al menos una donación para publicarse


# ValidAuditReport

acme.validation.auditReport.duplicated-ticker.message = Este ticker ya está en uso
acme.validation.auditReport.invalid-date-order.message = La fecha de fin debe ser posterior a la de inicio
acme.validation.auditReport.date-not-future.message = La fecha de inicio debe ser futura
acme.validation.auditReport.missing-auditSections.message = Un reporte de auditoría debe tener al menos una sección de auditoría para poder publicarse
acme.validation.auditReport.dates.error = La fecha de fin debe ser posterior a la de inicio
acme.validation.auditReport.startMoment.future = La fecha de inicio debe ser futura
acme.validation.auditReport.endMoment.future = La fecha de fin debe ser futura
acme.validation.auditReport.auditSection.error = Debe tener al menos una sección de auditoría para publicarse