# validation-en.i18n
# Global validation messages resolved by the Bean Validation message source.

# ValidTicker
acme.validation.ticker.message = The format must start with two uppercase letters, followed by two digits, a dash, and between 5 and 10 alphanumeric characters (e.g. AA00-ABCDE123).

# ValidStrategy
acme.validation.strategy.message = The strategy is not valid.
acme.validation.strategy.no-tactics.message = Cannot publish a strategy that has no tactics.
acme.validation.strategy.ticker-duplicated.message = This ticker is already in use by another strategy.
acme.validation.strategy.start-null.message = Start moment is required.
acme.validation.strategy.end-null.message = End moment is required.
acme.validation.strategy.start-not-future.message = Start moment must be in the future at publish time.
acme.validation.strategy.end-not-future.message = End moment must be in the future at publish time.
acme.validation.strategy.invalid-interval.message = Start moment must be before end moment.

# ValidText / ValidHeader (Shared)
acme.validation.header.message = Must be between 1 and 75 characters
acme.validation.text.message = Must be between 1 and 255 characters
acme.validation.object.message = Invalid value.

# ValidCampaign

acme.validation.campaign.no-milestones.message = Cannot publish a campaign that has no milestones.
acme.validation.campaign.start-not-future.message = Start moment must be in the future at publish time.
acme.validation.campaign.end-not-future.message = End moment must be in the future at publish time.
acme.validation.campaign.invalid-interval.message = Start moment must be before end moment.

# ValidSponsorship
acme.validation.sponsorship.duplicated-ticker.message = This ticker is already in use
acme.validation.sponsorship.invalid-date-order.message = End date must be after start date
acme.validation.sponsorship.date-not-future.message = Start date must be in the future
acme.validation.sponsorship.missing-donations.message = A sponsorship must have at least one donation to be published
acme.validation.sponsorship.dates.error = End date must be after start date
acme.validation.sponsorship.startMoment.future = Start date must be in the future
acme.validation.sponsorship.endMoment.future = End date must be in the future
acme.validation.sponsorship.donations.error = Must have at least one donation to publish
acme.validation.money.eur.error = Must be EUR

# ValidAuditReport
acme.validation.audit-report.duplicated-ticker.message = This ticker is already in use 
acme.validation.audit-report.ticker-duplicated.message = This ticker is already in use 
acme.validation.audit-report.invalid-date-order.message = End date must be after start date
acme.validation.audit-report.date-not-future.message = Start date must be in the future
acme.validation.auditReport.no-auditSections.message = An audit report must have at least one audit section to be published
acme.validation.audit-report.invalid-interval.message = End date must be after start date
